<?xml version="1.0" encoding="utf-8" ?>
<ContentPage
    x:Class="ScienceRecruiterApp.View.ResultsTabPage"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    xmlns:ListCollection="clr-namespace:System.Collections.Generic;assembly=mscorlib"
    xmlns:chart="clr-namespace:Syncfusion.SfChart.XForms;assembly=Syncfusion.SfChart.XForms"
    xmlns:combobox="clr-namespace:Syncfusion.XForms.ComboBox;assembly=Syncfusion.SfComboBox.XForms"
    xmlns:progressbar="clr-namespace:Syncfusion.XForms.ProgressBar;assembly=Syncfusion.SfProgressBar.XForms">
    <ContentPage.Content>
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="*" />
                <RowDefinition Height="3*" />
            </Grid.RowDefinitions>

            <StackLayout Grid.Row="0">


                <Label
                    FontSize="Title"
                    HorizontalOptions="CenterAndExpand"
                    Text="Points"
                    VerticalOptions="CenterAndExpand" />
                <StackLayout Orientation="Horizontal">
                    <Label
                        FontSize="Subtitle"
                        HorizontalOptions="Start"
                        HorizontalTextAlignment="Center"
                        Text="Total points:"
                        VerticalOptions="CenterAndExpand" />
                    <Label Text="Under development" />
                </StackLayout>
                <StackLayout Orientation="Horizontal">
                    <Label
                        FontSize="Subtitle"
                        HorizontalOptions="Start"
                        HorizontalTextAlignment="Center"
                        Text="Current rank:"
                        VerticalOptions="CenterAndExpand" />
                    <Label Text="{Binding CurrRank}" />
                </StackLayout>
                <Label
                    FontSize="Subtitle"
                    HorizontalOptions="CenterAndExpand"
                    HorizontalTextAlignment="Center"
                    Text="To the next rank:"
                    VerticalOptions="EndAndExpand" />
                <progressbar:SfLinearProgressBar
                    Margin="10"
                    EasingEffect="CubicInOut"
                    Progress="75" />
                <StackLayout Orientation="Horizontal">
                    <Label
                        HorizontalOptions="StartAndExpand"
                        HorizontalTextAlignment="Start"
                        Text="Youngling" />
                    <Label
                        HorizontalOptions="EndAndExpand"
                        HorizontalTextAlignment="Center"
                        Text="Padawan" />

                </StackLayout>

            </StackLayout>
            <Grid Grid.Row="1">
                <Grid.RowDefinitions>
                    <RowDefinition Height="*" />

                    <RowDefinition Height="3*" />
                    <RowDefinition Height="*" />
                </Grid.RowDefinitions>
                <Frame Grid.Row="0" BackgroundColor="Beige">
                    <StackLayout Orientation="Horizontal" VerticalOptions="EndAndExpand">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="3*" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>

                            <Label
                                Grid.Column="0"
                                FontSize="Title"
                                HorizontalOptions="CenterAndExpand"
                                HorizontalTextAlignment="Center"
                                Text="Behavioural results"
                                VerticalOptions="EndAndExpand"
                                VerticalTextAlignment="Center" />
                            <CarouselView
                                x:Name="carousel_Results"
                                Grid.Column="1"
                                CurrentItemChanged="ProgressBar_Changed"
                                Loop="False"
                                PeekAreaInsets="0">
                                <CarouselView.ItemsLayout>
                                    <LinearItemsLayout ItemSpacing="0" Orientation="Vertical" />
                                </CarouselView.ItemsLayout>
                                <CarouselView.ItemTemplate>
                                    <DataTemplate>


                                        <progressbar:SfCircularProgressBar
                                            x:Name="CircularProgressBar"
                                            EasingEffect="SinIn"
                                            HorizontalOptions="FillAndExpand"
                                            IndicatorInnerRadius="0.7"
                                            IndicatorOuterRadius="0.9"
                                            Maximum="{Binding MaximumTrials}"
                                            Progress="{Binding ProgressInt}"
                                            TrackInnerRadius="0.7"
                                            TrackOuterRadius="0.9"
                                            VerticalOptions="FillAndExpand">
                                            <progressbar:SfCircularProgressBar.Content>

                                                <StackLayout VerticalOptions="FillAndExpand">
                                                    <StackLayout.GestureRecognizers>
                                                        <TapGestureRecognizer Tapped="ProgressBar_Tapped" />
                                                    </StackLayout.GestureRecognizers>
                                                    <Label
                                                        HorizontalOptions="Center"
                                                        HorizontalTextAlignment="Center"
                                                        LineBreakMode="WordWrap"
                                                        Text="{Binding ShortTitle}"
                                                        VerticalOptions="Center" />
                                                </StackLayout>

                                            </progressbar:SfCircularProgressBar.Content>
                                        </progressbar:SfCircularProgressBar>


                                    </DataTemplate>
                                </CarouselView.ItemTemplate>
                            </CarouselView>
                        </Grid>
                    </StackLayout>
                </Frame>
                <Grid x:Name="Details_Layout" Grid.Row="1">
                    <!--<Grid.RowDefinitions>
                        <RowDefinition Height="*" />
                        <RowDefinition Height="4*" />
                    </Grid.RowDefinitions>
                    <StackLayout Grid.Row="0">
                        <Label
                            FontSize="Medium"
                            HorizontalOptions="CenterAndExpand"
                            HorizontalTextAlignment="Center"
                            Text="Selection currently unavailable:"
                            VerticalOptions="StartAndExpand"
                            VerticalTextAlignment="Center" />
                        <combobox:SfComboBox>
                            <combobox:SfComboBox.ComboBoxSource>
                                <ListCollection:List x:TypeArguments="x:String">
                                    <x:String>Reaction time</x:String>
                                </ListCollection:List>
                            </combobox:SfComboBox.ComboBoxSource>
                        </combobox:SfComboBox>
                        <Label Text="Selection currently unavailable" />
                    </StackLayout>-->
                    <StackLayout Grid.Row="0">

                        <chart:SfChart VerticalOptions="FillAndExpand">
                            <chart:SfChart.Title>
                                <chart:ChartTitle Text="{Binding Title}" />
                            </chart:SfChart.Title>
                            <chart:SfChart.PrimaryAxis>
                                <chart:CategoryAxis IsVisible="true" />
                            </chart:SfChart.PrimaryAxis>
                            <chart:SfChart.SecondaryAxis>
                                <chart:NumericalAxis IsVisible="true" />
                            </chart:SfChart.SecondaryAxis>
                            <chart:ColumnSeries ItemsSource="{Binding LongDescription}" />
                        </chart:SfChart>
                    </StackLayout>

                </Grid>
                <StackLayout x:Name="Explanation_layout" Grid.Row="2">
                    <Label
                        FontSize="Subtitle"
                        HorizontalOptions="CenterAndExpand"
                        HorizontalTextAlignment="Center"
                        Text="Explanation"
                        VerticalOptions="CenterAndExpand"
                        VerticalTextAlignment="Center" />
                    <Label
                        FontSize="Medium"
                        HorizontalOptions="CenterAndExpand"
                        HorizontalTextAlignment="Center"
                        Text="{Binding ShortDescription}"
                        VerticalOptions="CenterAndExpand"
                        VerticalTextAlignment="Center" />
                </StackLayout>
            </Grid>
        </Grid>
    </ContentPage.Content>
</ContentPage>  