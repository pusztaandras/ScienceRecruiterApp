<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="ScienceRecruiterApp.View.FirstPage"
             xmlns:progressBar="clr-namespace:Syncfusion.XForms.ProgressBar;assembly=Syncfusion.SfProgressBar.XForms"
             xmlns:syncfusion="clr-namespace:Syncfusion.XForms.Buttons;assembly=Syncfusion.Buttons.XForms">
    <ContentPage.Content>
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="4*" />
                <RowDefinition Height="*" />
                <RowDefinition Height="*" />
            </Grid.RowDefinitions>
            <StackLayout Grid.Row="0" VerticalOptions="CenterAndExpand">
                <ScrollView>
                  <Label Text="{Binding PrivacyText}" HorizontalOptions="Center" VerticalOptions="Center"/>
                </ScrollView>
            </StackLayout>
            <StackLayout Grid.Row="1" VerticalOptions="EndAndExpand">
                <syncfusion:SfCheckBox x:Name="CheckBox_accept" Text="I read and accept the privacy policy" IsChecked="False" HorizontalOptions="Center" VerticalOptions="Center"/>
                <Button Text="Next" HorizontalOptions="Center" Clicked="Button_Clicked" VerticalOptions="Center"/>
            </StackLayout>

            <progressBar:SfStepProgressBar HorizontalOptions="Center" VerticalOptions="Center" Grid.Row="2">
                <progressBar:StepView PrimaryText="Privacy Policy" Status="InProgress" />
                <progressBar:StepView PrimaryText="Terms and Conditions" />
                <progressBar:StepView PrimaryText="Informations" />
            </progressBar:SfStepProgressBar>
        </Grid>
    </ContentPage.Content>
</ContentPage>